# Base URL of the Spring Boot backend. No trailing slash.
VITE_API_BASE_URL=http://localhost:8080

# Cloudflare Turnstile site key (public). Leave unset for local dev — the signup form falls back
# to submitting a placeholder token, which the backend accepts as long as
# CAPTCHA_TURNSTILE_SECRET_KEY is also unset on its side (see backend CaptchaVerifier).
VITE_TURNSTILE_SITE_KEY=
